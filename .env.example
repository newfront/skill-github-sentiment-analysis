# Copy this file to .env and fill in your values.
#   cp .env.example .env
#
# .env is gitignored — never commit it.
# .env.example IS committed — keep it free of real secrets.

# ---------------------------------------------------------------------------
# LLM Provider
# ---------------------------------------------------------------------------

# Which provider to use for nuanced tone analysis + summarization.
# Options: openai | anthropic | databricks
# Default: openai
LLM_PROVIDER=openai

# Override the model name (optional — each provider has a sensible default).
# openai default:     gpt-4o-mini
# anthropic default:  claude-3-haiku-20240307
# databricks default: databricks-meta-llama/Meta-Llama-3.1-70B-Instruct
# LLM_MODEL=gpt-4o-mini

# ---------------------------------------------------------------------------
# OpenAI
# ---------------------------------------------------------------------------
OPENAI_API_KEY=sk-...

# ---------------------------------------------------------------------------
# Anthropic (only needed if LLM_PROVIDER=anthropic)
# ---------------------------------------------------------------------------
# ANTHROPIC_API_KEY=sk-ant-...

# ---------------------------------------------------------------------------
# Databricks (only needed if LLM_PROVIDER=databricks)
# ---------------------------------------------------------------------------
# DATABRICKS_HOST=https://your-workspace.azuredatabricks.net
# DATABRICKS_TOKEN=dapi...

# ---------------------------------------------------------------------------
# Sentiment pipeline tuning
# ---------------------------------------------------------------------------

# Max concurrent LLM calls when running --sentiment over multiple issues.
# Default: 5
# SENTIMENT_MAX_WORKERS=5

# ---------------------------------------------------------------------------
# MLflow Tracing (optional)
# ---------------------------------------------------------------------------

# Remote tracking server URI. Leave unset to skip tracing entirely.
# MLFLOW_TRACKING_URI=https://your-mlflow-server

# Experiment name for sentiment traces (used if MLFLOW_EXPERIMENT_ID is not set).
# Default: gh-issues-sentiment
# MLFLOW_EXPERIMENT_NAME=gh-issues-sentiment
